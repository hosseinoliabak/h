{
  "rules": {
    "rooms": {
      ".read": false,
      "$room": {
        ".read": true,
        ".write": "$room.length <= 32 && $room.matches(/^[a-zA-Z0-9_-]+$/)",
        "content": {
          ".validate": "newData.isString() && newData.val().length < 1000000"
        },
        "image": {
          ".validate": "newData.isString() && newData.val().length < 700000"
        },
        "files": {
          "$fileId": {
            ".validate": "newData.hasChildren(['name', 'size', 'content', 'uploadedAt', 'uploadedBy'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 300"
            },
            "size": {
              ".validate": "newData.isNumber()"
            },
            "content": {
              ".validate": "newData.isString() && newData.val().length < 7500000"
            },
            "uploadedAt": {
              ".validate": "newData.isNumber()"
            },
            "uploadedBy": {
              ".validate": "newData.isString() && newData.val().length <= 100"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "members": {
          "$member": {
            ".validate": "newData.hasChildren(['name', 'joinedAt'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 100"
            },
            "joinedAt": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "lastDisconnect": {
          ".validate": "newData.isNumber()"
        },
        "history": {
          "$msg": {
            ".validate": "$msg.length <= 24 && $msg.matches(/^[a-z0-9]+$/) && newData.hasChildren(['text','timestamp'])",
            "text": {
              ".validate": "newData.isString() && newData.val().length < 1000000"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "sender": {
              ".validate": "newData.isString() && newData.val().length <= 100"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "cleanup": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "pageviews": {
      ".read": true,
      "$key": {
        ".write": "$key.length <= 64 && $key.matches(/^[a-zA-Z0-9_-]+$/)",
        ".validate": "newData.isNumber() && (data.exists() ? newData.val() === data.val() + 1 : newData.val() === 1)"
      }
    },
    "chess": {
      "players": {
        ".read": true,
        ".indexOn": [
          "level"
        ],
        "$player": {
          ".write": "$player.matches(/^[A-Z2-9]{12}$/)",
          ".validate": "newData.hasChildren(['name', 'updatedAt'])",
          "name": {
            ".validate": "newData.isString() && newData.val().matches(/^[A-Za-z0-9][A-Za-z0-9 -]{0,19}$/)"
          },
          "level": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 4000"
          },
          "games": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"
          },
          "wins": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "draws": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "losses": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "bestWin": {
            ".validate": "newData.isString() && newData.val().length <= 20"
          },
          "updatedAt": {
            ".validate": "newData.isNumber()"
          },
          "recent": {
            "$i": {
              ".validate": "$i.matches(/^[0-9]$/) && newData.hasChildren(['t','bot','result'])",
              "t": {
                ".validate": "newData.isNumber()"
              },
              "bot": {
                ".validate": "newData.isString() && newData.val().length <= 20"
              },
              "color": {
                ".validate": "newData.val() == 'w' || newData.val() == 'b'"
              },
              "result": {
                ".validate": "newData.isString() && newData.val().length <= 8"
              },
              "tc": {
                ".validate": "newData.isString() && newData.val().length <= 8"
              },
              "moves": {
                ".validate": "newData.isNumber()"
              },
              "perf": {
                "elo": {
                  ".validate": "newData.isNumber()"
                },
                "acpl": {
                  ".validate": "newData.isNumber()"
                },
                "n": {
                  ".validate": "newData.isNumber()"
                },
                "$other": {
                  ".validate": false
                }
              },
              "pgn": {
                ".validate": "newData.isString() && newData.val().length <= 8000"
              },
              "$other": {
                ".validate": false
              }
            }
          },
          "$other": {
            ".validate": false
          }
        }
      },
      "$other": {
        ".validate": false
      }
    }
  }
}