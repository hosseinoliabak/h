<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language SYSTEM "language.dtd">
<language name="YANG" section="Sources" extensions="*.yang" mimetype="text/x-yang" version="1" kateversion="5.0" author="Custom" license="MIT">
  <highlighting>
    <general>
      <keywords weakDeliminator="-"/>
    </general>
    <list name="keywords">
      <item>module</item>
      <item>submodule</item>
      <item>namespace</item>
      <item>prefix</item>
      <item>import</item>
      <item>include</item>
      <item>revision</item>
      <item>container</item>
      <item>list</item>
      <item>leaf</item>
      <item>leaf-list</item>
      <item>choice</item>
      <item>case</item>
      <item>grouping</item>
      <item>uses</item>
      <item>augment</item>
      <item>notification</item>
      <item>rpc</item>
      <item>input</item>
      <item>output</item>
      <item>typedef</item>
      <item>type</item>
      <item>key</item>
      <item>config</item>
      <item>mandatory</item>
      <item>default</item>
      <item>description</item>
      <item>reference</item>
      <item>when</item>
      <item>if-feature</item>
      <item>feature</item>
      <item>identity</item>
      <item>base</item>
      <item>enum</item>
      <item>bit</item>
      <item>range</item>
      <item>length</item>
      <item>pattern</item>
      <item>fraction-digits</item>
      <item>min-elements</item>
      <item>max-elements</item>
      <item>ordered-by</item>
      <item>unique</item>
      <item>enumeration</item>
    </list>
    <list name="types">
      <item>string</item>
      <item>int8</item>
      <item>int16</item>
      <item>int32</item>
      <item>int64</item>
      <item>uint8</item>
      <item>uint16</item>
      <item>uint32</item>
      <item>uint64</item>
      <item>boolean</item>
      <item>empty</item>
      <item>binary</item>
      <item>decimal64</item>
      <item>leafref</item>
      <item>identityref</item>
      <item>union</item>
      <item>instance-identifier</item>
    </list>
    <contexts>
      <context name="Normal" attribute="Normal Text" lineBeginContext="#stay" lineEndContext="#stay">
        <keyword attribute="Keyword" context="#stay" String="keywords"/>
        <keyword attribute="Data Type" context="#stay" String="types"/>
        <DetectChar attribute="String" context="String" char="&quot;"/>
        <DetectChar attribute="String" context="SingleString" char="'"/>
        <Detect2Chars attribute="Comment" context="Comment" char="/" char1="/"/>
        <Detect2Chars attribute="Comment" context="BlockComment" char="/" char1="*"/>
        <DetectChar attribute="Symbol" context="#stay" char="{"/>
        <DetectChar attribute="Symbol" context="#stay" char="}"/>
        <DetectChar attribute="Symbol" context="#stay" char=";"/>
      </context>
      <context name="String" attribute="String" lineBeginContext="#stay" lineEndContext="#stay">
        <DetectChar attribute="String" context="#pop" char="&quot;"/>
      </context>
      <context name="SingleString" attribute="String" lineBeginContext="#stay" lineEndContext="#stay">
        <DetectChar attribute="String" context="#pop" char="'"/>
      </context>
      <context name="Comment" attribute="Comment" lineBeginContext="#stay" lineEndContext="#pop">
      </context>
      <context name="BlockComment" attribute="Comment" lineBeginContext="#stay" lineEndContext="#stay">
        <Detect2Chars attribute="Comment" context="#pop" char="*" char1="/"/>
      </context>
    </contexts>
    <itemDatas>
      <itemData name="Normal Text" defStyleNum="dsNormal"/>
      <itemData name="Keyword" defStyleNum="dsKeyword"/>
      <itemData name="Data Type" defStyleNum="dsDataType"/>
      <itemData name="String" defStyleNum="dsString"/>
      <itemData name="Comment" defStyleNum="dsComment"/>
      <itemData name="Symbol" defStyleNum="dsNormal"/>
    </itemDatas>
  </highlighting>
</language>
