        "def newtons_method(dfdx, d2fdx2, x, num_iterations=100):\n",
        "    path = [x]\n",
        "    for _ in range(num_iterations):\n",
        "        x = x - dfdx(x) / d2fdx2(x)\n",
        "        path.append(x)\n",
        "    return x, path\n",
        "\n",
        "def gradient_descent(dfdx, x, learning_rate=0.1, num_iterations=100):\n",
        "    path = [x]\n",
        "    for _ in range(num_iterations):\n",
        "        x = x - learning_rate * dfdx(x)\n",
        "        path.append(x)\n",
        "    return x, path"
