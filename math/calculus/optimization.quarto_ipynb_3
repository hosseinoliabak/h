        "\n",
        "x = np.linspace(0, 4, 500)\n",
        "# Wavy function: starts at 85, clear local min, high peak, then global min further right\n",
        "T = 85 - 8*np.sin(1.5*np.pi*x) + 3*np.sin(3*np.pi*x) - 2*x\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 5.5))\n",
        "ax.plot(x, T, color='black', linewidth=2.5)\n",
        "\n",
        "# Find critical points numerically\n",
        "dT = np.gradient(T, x)\n",
        "d2T = np.gradient(dT, x)\n",
        "sign_changes = np.where(np.diff(np.sign(dT)))[0]\n",
        "\n",
        "crits_x, crits_T, crit_types = [], [], []\n",
