        "#| echo: false\n",
        "#| fig-align: center\n",
        "\n",
        "%config InlineBackend.figure_formats = ['svg']\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x = np.linspace(-1, 8, 300)\n",
        "positions = [1, 6, 8]\n",
        "colors_p = ['#4682B4', '#CC7000', '#2E8B57']\n",
        "labels_p = ['$(x-1)^2$', '$(x-6)^2$', '$(x-8)^2$']\n",
        "\n",
        "# Individual parabolas\n",
        "parabolas = [(x - p)**2 for p in positions]\n",
        "C = sum(parabolas)\n",
        "x_opt = np.mean(positions)\n",
        "C_opt = sum((x_opt - p)**2 for p in positions)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9, 5))\n",
        "\n",
        "# Plot individual parabolas (faded)\n",
        "for para, c, lab in zip(parabolas, colors_p, labels_p):\n",
        "    ax.plot(x, para, '--', color=c, linewidth=1.5, alpha=0.5, label=lab)\n",
        "\n",
        "# Plot total cost (bold black)\n",
        "ax.plot(x, C, color='black', linewidth=2.5, label='$C(x)$ (sum)')\n",
        "\n",
        "# Mark power line positions\n",
        "for p, c in zip(positions, colors_p):\n",
        "    ax.axvline(p, color=c, linewidth=1.5, linestyle=':', alpha=0.5)\n",
        "\n",
        "# Mark the minimum\n",
        "ax.plot(x_opt, C_opt, '*', color='#2E8B57', markersize=16, zorder=5)\n",
        "ax.annotate(f'Minimum at $x = 5$\\n(the mean)', xy=(x_opt, C_opt), xytext=(x_opt, C_opt + 8),\n",
        "            fontsize=10, fontweight='bold', color='#2E8B57', ha='center',\n",
        "            arrowprops=dict(arrowstyle='->', color='#2E8B57'))\n",
        "\n",
        "# Tangent at minimum\n",
        "t = np.linspace(x_opt - 0.8, x_opt + 0.8, 50)\n",
        "ax.plot(t, np.full_like(t, C_opt), '-', color='#CC0000', linewidth=2, alpha=0.7)\n",
        "\n",
        "ax.set_xlabel('House position $x$', fontsize=11)\n",
        "ax.set_ylabel('Cost', fontsize=11)\n",
        "ax.set_ylim(0, 50)\n",
        "ax.set_title('Individual parabolas sum to the total cost curve', fontsize=12, color='gray')\n",
        "ax.grid(True, linestyle='--', alpha=0.4)\n",
        "ax.legend(fontsize=9, loc='center left')\n",
        "plt.tight_layout()\n",
        "plt.show()"
