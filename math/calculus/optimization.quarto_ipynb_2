        "#| echo: false\n",
        "#| fig-align: center\n",
        "\n",
        "%config InlineBackend.figure_formats = ['svg']\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x = np.linspace(-1, 7, 200)\n",
        "a, b = 1, 5\n",
        "C = (x - a)**2 + (x - b)**2\n",
        "x_opt = (a + b) / 2\n",
        "C_opt = (x_opt - a)**2 + (x_opt - b)**2\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8, 4.5))\n",
        "ax.plot(x, C, color='#4682B4', linewidth=2.5, label='$C(x) = (x-1)^2 + (x-5)^2$')\n",
        "\n",
        "# Mark power line positions\n",
        "ax.axvline(a, color='#4682B4', linewidth=1.5, linestyle=':', alpha=0.7)\n",
        "ax.axvline(b, color='#CC7000', linewidth=1.5, linestyle=':', alpha=0.7)\n",
        "ax.text(a, max(C)*0.92, '$a = 1$', fontsize=11, ha='center', color='#4682B4', fontweight='bold')\n",
        "ax.text(b, max(C)*0.92, '$b = 5$', fontsize=11, ha='center', color='#CC7000', fontweight='bold')\n",
        "\n",
        "# Mark the minimum\n",
        "ax.plot(x_opt, C_opt, '*', color='#2E8B57', markersize=16, zorder=5)\n",
        "ax.annotate(f'Minimum at $x = (a+b)/2 = 3$\\n$C = {C_opt:.0f}$', xy=(x_opt, C_opt), xytext=(x_opt, C_opt + 8),\n",
        "            fontsize=10, fontweight='bold', color='#2E8B57', ha='center',\n",
        "            arrowprops=dict(arrowstyle='->', color='#2E8B57'))\n",
        "\n",
        "ax.set_xlabel('House position $x$', fontsize=11)\n",
        "ax.set_ylabel('Total cost $C(x)$', fontsize=11)\n",
        "ax.set_title('Two power lines: the optimal position is the midpoint', fontsize=12, color='gray')\n",
        "ax.grid(True, linestyle='--', alpha=0.4)\n",
        "ax.legend(fontsize=10)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
