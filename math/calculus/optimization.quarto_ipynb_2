        "#| echo: false\n",
        "#| fig-align: center\n",
        "\n",
        "%config InlineBackend.figure_formats = ['svg']\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x = np.linspace(0, 4, 500)\n",
        "# Wavy function: starts at 85, clear local min, high peak, then global min further right\n",
        "T = 85 - 8*np.sin(1.5*np.pi*x) + 3*np.sin(3*np.pi*x) - 2*x\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 5.5))\n",
        "ax.plot(x, T, color='black', linewidth=2.5)\n",
        "\n",
        "# Find critical points numerically\n",
        "dT = np.gradient(T, x)\n",
        "d2T = np.gradient(dT, x)\n",
        "sign_changes = np.where(np.diff(np.sign(dT)))[0]\n",
        "\n",
        "crits_x, crits_T, crit_types = [], [], []\n",
        "for i in sign_changes:\n",
        "    cx = x[i]\n",
        "    cT = T[i]\n",
        "    tp = 'min' if d2T[i] > 0 else 'max'\n",
        "    crits_x.append(cx)\n",
        "    crits_T.append(cT)\n",
        "    crit_types.append(tp)\n",
        "\n",
        "# Plot horizontal tangent lines (slope=0) at all critical points\n",
        "for cx, cT, tp in zip(crits_x, crits_T, crit_types):\n",
        "    t_line = np.linspace(cx - 0.15, cx + 0.15, 30)\n",
        "    ax.plot(t_line, np.full_like(t_line, cT), '-', color='#4682B4', linewidth=3, zorder=4)\n",
        "    ax.plot(cx, cT, 'o', color='#4682B4', markersize=7, zorder=6)\n",
        "\n",
        "# Identify minima\n",
        "min_indices = [i for i, t in enumerate(crit_types) if t == 'min']\n",
        "global_min_idx = min(min_indices, key=lambda i: crits_T[i])\n",
        "\n",
        "# Label global minimum (above the point)\n",
        "gx, gT = crits_x[global_min_idx], crits_T[global_min_idx]\n",
