        "    .text(`y = ${path[0].m.toFixed(2)}x + ${path[0].b.toFixed(2)}`);\n",
        "\n",
        "  // === RIGHT PLOT: Cost contour ===\n",
        "  const offset = leftW + 20;\n",
        "  const mS = d3.scaleLinear().domain([-1, 2]).range([offset + m_margin.left, W - m_margin.right]);\n",
        "  const bS = d3.scaleLinear().domain([-1, 4]).range([H - m_margin.bottom, m_margin.top]);\n",
        "\n",
        "  const res = 50;\n",
