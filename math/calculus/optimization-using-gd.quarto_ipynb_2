        "  const colorScale = d3.scaleSequential(d3.interpolateYlOrRd).domain([0, 120]);\n",
        "\n",
        "  for (let i = 0; i < res; i++) {\n",
        "    for (let j = 0; j < res; j++) {\n",
        "      const cm = -1 + (i + 0.5) * 3 / res;\n",
        "      const cb = -1 + (j + 0.5) * 5 / res;\n",
