        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x_plot = np.linspace(-1, 6, 200)\n",
        "f_plot = x_plot**2 - 4*x_plot + 7\n",
        "\n",
        "# Run GD\n",
