   "source": [
    "#| echo: false\n",
    "#| fig-align: center\n",
    "\n",
    "%config InlineBackend.figure_formats = ['svg']\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import Polygon\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6, 5))\n",
    "\n",
    "pts = np.array([[0, 0], [3, -1], [5, 2], [2, 3]])\n",
    "poly = Polygon(pts, closed=True, fc='#FFB347', ec='#CC7000', lw=2, alpha=0.4)\n",
    "ax.add_patch(poly)\n",
    "\n",
    "labels = ['$(0,0)$', '$(3,-1)$', '$(5,2)$', '$(2,3)$']\n",
    "offsets = [(-0.5, -0.4), (0.15, -0.4), (0.15, 0.2), (-0.7, 0.2)]\n",
    "for pt, label, off in zip(pts, labels, offsets):\n",
    "    ax.plot(*pt, 'o', color='#CC7000', markersize=7, zorder=5)\n",
    "    ax.text(pt[0] + off[0], pt[1] + off[1], label, fontsize=11, color='#CC7000')\n",
    "\n",
    "ax.set_xlim(-1, 6)\n",
    "ax.set_ylim(-2, 4)\n",
    "ax.set_aspect('equal')\n",
    "ax.set_xticks(range(-1, 7))\n",
    "ax.set_yticks(range(-2, 5))\n",
    "ax.grid(True, linestyle='--', alpha=0.4)\n",
    "ax.axhline(0, color='black', linewidth=0.8)\n",
    "ax.axvline(0, color='black', linewidth=0.8)\n",
    "ax.set_title('Transformed parallelogram', fontsize=12, color='gray')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
