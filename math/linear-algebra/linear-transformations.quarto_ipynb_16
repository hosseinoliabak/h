    "#| echo: false\n",
    "#| fig-align: center\n",
    "\n",
    "%config InlineBackend.figure_formats = ['svg']\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import Polygon\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 5.5))\n",
    "\n",
    "A = np.array([[3, 1], [1, 2]])\n",
    "p = np.array([-2, 3])\n",
    "Ap = A @ p\n",
    "\n",
    "# --- Left: original grid ---\n",
    "ax = axes[0]\n",
    "for i in range(-4, 5):\n",
    "    for j in range(-4, 5):\n",
    "        sq = np.array([[i, j], [i+1, j], [i+1, j+1], [i, j+1]])\n",
    "        poly = Polygon(sq, closed=True, fc='#87CEEB', ec='#4682B4', lw=0.5, alpha=0.15)\n",
    "        ax.add_patch(poly)\n",
    "\n",
    "ax.annotate('', xy=p, xytext=(0, 0),\n",
    "            arrowprops=dict(arrowstyle='->', color='#C71585', lw=2.5))\n",
    "ax.plot(*p, 'o', color='#C71585', markersize=8, zorder=5)\n",
    "ax.text(p[0] - 0.6, p[1] + 0.2, '$(-2, 3)$', fontsize=12, color='#C71585', fontweight='bold')\n",
    "\n",
    "ax.set_xlim(-8, 4)\n",
    "ax.set_ylim(-4, 8)\n",
    "ax.set_aspect('equal')\n",
    "ax.set_xticks(range(-8, 5))\n",
    "ax.set_yticks(range(-4, 9))\n",
    "ax.grid(True, linestyle='--', alpha=0.3)\n",
    "ax.axhline(0, color='black', linewidth=0.8)\n",
    "ax.axvline(0, color='black', linewidth=0.8)\n",
    "ax.set_title('Original coordinates', fontsize=12, color='gray')\n",
    "\n",
    "# --- Right: transformed grid ---\n",
    "ax = axes[1]\n",
    "e1 = A[:, 0]  # (3, 1)\n",
    "e2 = A[:, 1]  # (1, 2)\n",
    "for i in range(-4, 5):\n",
    "    for j in range(-4, 5):\n",
    "        corners = np.array([\n",
    "            i * e1 + j * e2,\n",
    "            (i+1) * e1 + j * e2,\n",
    "            (i+1) * e1 + (j+1) * e2,\n",
    "            i * e1 + (j+1) * e2\n",
    "        ])\n",
    "        poly = Polygon(corners, closed=True, fc='#FFB347', ec='#CC7000', lw=0.5, alpha=0.15)\n",
    "        ax.add_patch(poly)\n",
    "\n",
    "# Show the walking steps: -2 along e1, then +3 along e2\n",
    "step1 = -2 * e1  # first stop after -2 steps along (3,1)\n",
    "step2 = step1 + 3 * e2  # final point after +3 steps along (1,2) = Ap\n",
    "\n",
    "# Step 1: walk -2 along e1 (origin to step1)\n",
    "ax.annotate('', xy=step1, xytext=(0, 0),\n",
    "            arrowprops=dict(arrowstyle='->', color='steelblue', lw=2, linestyle='--'))\n",
    "ax.text(step1[0] - 0.3, step1[1] - 0.6,\n",
    "        r'$-2 \\times (3,1)$', fontsize=10, color='steelblue')\n",
    "\n",
    "# Step 2: walk +3 along e2 (step1 to final point)\n",
    "ax.annotate('', xy=step2, xytext=step1,\n",
    "            arrowprops=dict(arrowstyle='->', color='darkorange', lw=2, linestyle='--'))\n",
    "ax.text(step1[0] + 0.8, (step1[1] + step2[1]) / 2,\n",
    "        r'$+3 \\times (1,2)$', fontsize=10, color='darkorange')\n",
    "\n",
    "# Final point\n",
    "ax.plot(*Ap, 'o', color='#C71585', markersize=8, zorder=5)\n",
    "ax.text(Ap[0] - 1.5, Ap[1] + 0.3, '$(-3, 4)$', fontsize=12, color='#C71585', fontweight='bold')\n",
    "\n",
    "ax.set_xlim(-8, 4)\n",
    "ax.set_ylim(-4, 8)\n",
    "ax.set_aspect('equal')\n",
    "ax.set_xticks(range(-8, 5))\n",
    "ax.set_yticks(range(-4, 9))\n",
    "ax.grid(True, linestyle='--', alpha=0.3)\n",
    "ax.axhline(0, color='black', linewidth=0.8)\n",
    "ax.axvline(0, color='black', linewidth=0.8)\n",
    "ax.set_title('Transformed coordinates', fontsize=12, color='gray')\n",
    "\n",
    "plt.tight_layout(pad=0.5)\n",
    "plt.show()"
   ]
