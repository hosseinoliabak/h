    "#| echo: false\n",
    "#| fig-align: center\n",
    "\n",
    "%config InlineBackend.figure_formats = ['svg']\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import Polygon\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 4.5))\n",
    "\n",
    "A = np.array([[3, 1], [1, 2]])\n",
    "A_inv = np.linalg.inv(A)\n",
    "\n",
    "pts = np.array([[0, 0], [1, 0], [1, 1], [0, 1]])\n",
    "pts_t = (A @ pts.T).T\n",
    "pts_back = (A_inv @ pts_t.T).T\n",
    "\n",
    "configs = [\n",
    "    (axes[0], pts, '#87CEEB', '#4682B4', 'Original'),\n",
    "    (axes[1], pts_t, '#FFB347', '#CC7000', 'After $A$'),\n",
    "    (axes[2], pts_back, '#87CEEB', '#4682B4', 'After $A^{-1}$ (back to original)'),\n",
    "]\n",
    "\n",
    "for ax, p, fc, ec, title in configs:\n",
    "    poly = Polygon(p, closed=True, fc=fc, ec=ec, lw=2, alpha=0.4)\n",
    "    ax.add_patch(poly)\n",
    "    for pt in p:\n",
    "        ax.plot(*pt, 'o', color=ec, markersize=5, zorder=5)\n",
    "    ax.set_xlim(-1, 5)\n",
    "    ax.set_ylim(-1, 4)\n",
    "    ax.set_aspect('equal')\n",
    "    ax.grid(True, linestyle='--', alpha=0.4)\n",
    "    ax.axhline(0, color='black', linewidth=0.8)\n",
    "    ax.axvline(0, color='black', linewidth=0.8)\n",
    "    ax.set_title(title, fontsize=12, color='gray')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
