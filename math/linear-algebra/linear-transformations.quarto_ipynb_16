    "#| echo: false\n",
    "#| fig-align: center\n",
    "\n",
    "%config InlineBackend.figure_formats = ['svg']\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import Polygon\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(14, 4.5))\n",
    "\n",
    "# original square\n",
    "pts = np.array([[0, 0], [1, 0], [1, 1], [0, 1]])\n",
    "\n",
    "transforms = [\n",
    "    ('Scaling (2, 1)', np.array([[2, 0], [0, 1]])),\n",
    "    ('Rotation (45$\\\\degree$)', np.array([[np.cos(np.pi/4), -np.sin(np.pi/4)],\n",
    "                                          [np.sin(np.pi/4),  np.cos(np.pi/4)]])),\n",
    "    ('Reflection ($a$-axis)', np.array([[1, 0], [0, -1]])),\n",
    "]\n",
    "\n",
    "for ax, (title, M) in zip(axes, transforms):\n",
    "    pts_t = (M @ pts.T).T\n",
    "\n",
    "    poly_orig = Polygon(pts, closed=True, fc='#87CEEB', ec='#4682B4', lw=1.5, alpha=0.3)\n",
    "    poly_trans = Polygon(pts_t, closed=True, fc='#FFB347', ec='#CC7000', lw=2, alpha=0.5)\n",
    "    ax.add_patch(poly_orig)\n",
    "    ax.add_patch(poly_trans)\n",
    "\n",
    "    ax.set_xlim(-1.5, 2.5)\n",
    "    ax.set_ylim(-1.5, 2)\n",
    "    ax.set_aspect('equal')\n",
    "    ax.grid(True, linestyle='--', alpha=0.4)\n",
    "    ax.axhline(0, color='black', linewidth=0.8)\n",
    "    ax.axvline(0, color='black', linewidth=0.8)\n",
    "    ax.set_title(title, fontsize=11, color='gray')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
