    "#| echo: false\n",
    "#| fig-align: center\n",
    "\n",
    "%config InlineBackend.figure_formats = ['svg']\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6, 5))\n",
    "\n",
    "data = [(0,0,0), (2,1,1), (1,1,1), (0,2,1), (0,1,0), (1,0,0)]\n",
    "\n",
    "for lot, win, spam in data:\n",
    "    color = '#CD5C5C' if spam else '#4682B4'\n",
    "    marker = 's' if spam else 'o'\n",
    "    ax.plot(lot, win, marker, color=color, markersize=12, zorder=5)\n",
    "    ax.text(lot + 0.1, win + 0.1, f'({lot},{win})', fontsize=9, color=color)\n",
    "\n",
    "x_line = np.linspace(-0.5, 2.5, 100)\n",
    "y_line = 1.5 - x_line\n",
    "ax.plot(x_line, y_line, '--', color='gray', lw=2, label='$x + y = 1.5$')\n",
    "ax.fill_between(x_line, y_line, 3, alpha=0.06, color='#CD5C5C')\n",
    "ax.fill_between(x_line, -0.5, y_line, alpha=0.06, color='#4682B4')\n",
    "\n",
    "ax.text(1.8, 2.2, 'Spam region', fontsize=10, color='#CD5C5C', fontstyle='italic')\n",
    "ax.text(0.1, -0.3, 'Not spam region', fontsize=10, color='#4682B4', fontstyle='italic')\n",
    "\n",
    "ax.set_xlabel('\"lottery\" count')\n",
    "ax.set_ylabel('\"win\" count')\n",
    "ax.set_xlim(-0.5, 2.5)\n",
    "ax.set_ylim(-0.5, 2.5)\n",
    "ax.set_aspect('equal')\n",
    "ax.grid(True, linestyle='--', alpha=0.4)\n",
    "ax.legend(fontsize=10)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
