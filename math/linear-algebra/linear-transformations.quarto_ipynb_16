    "#| echo: false\n",
    "#| fig-align: center\n",
    "\n",
    "%config InlineBackend.figure_formats = ['svg']\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.patches import Polygon\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "A = np.array([[3, 1], [1, 2]])\n",
    "\n",
    "# original points\n",
    "pts_orig = np.array([[0, 0], [1, 0], [1, 1], [0, 1]])\n",
    "# transformed points\n",
    "pts_trans = (A @ pts_orig.T).T\n",
    "\n",
    "# --- Left: original ---\n",
    "ax = axes[0]\n",
    "poly = Polygon(pts_orig, closed=True, fc='#87CEEB', ec='#4682B4', lw=2, alpha=0.4)\n",
    "ax.add_patch(poly)\n",
    "\n",
    "labels_orig = ['$(0,0)$', '$(1,0)$', '$(1,1)$', '$(0,1)$']\n",
    "offsets_orig = [(-0.3, -0.3), (0.15, -0.3), (0.15, 0.15), (-0.5, 0.15)]\n",
    "for pt, label, off in zip(pts_orig, labels_orig, offsets_orig):\n",
    "    ax.plot(*pt, 'o', color='#4682B4', markersize=7, zorder=5)\n",
    "    ax.text(pt[0] + off[0], pt[1] + off[1], label, fontsize=11, color='#4682B4')\n",
    "\n",
    "ax.set_xlim(-1, 5)\n",
    "ax.set_ylim(-1, 4.5)\n",
    "ax.set_aspect('equal')\n",
    "ax.grid(True, linestyle='--', alpha=0.4)\n",
    "ax.axhline(0, color='black', linewidth=0.8)\n",
    "ax.axvline(0, color='black', linewidth=0.8)\n",
    "ax.set_xlabel('$a$')\n",
    "ax.set_ylabel('$b$')\n",
    "ax.set_title('Original (unit square)', fontsize=12, color='gray')\n",
    "\n",
    "# --- Right: transformed ---\n",
    "ax = axes[1]\n",
    "poly_t = Polygon(pts_trans, closed=True, fc='#FFB347', ec='#CC7000', lw=2, alpha=0.4)\n",
    "ax.add_patch(poly_t)\n",
    "\n",
    "labels_trans = ['$(0,0)$', '$(3,1)$', '$(4,3)$', '$(1,2)$']\n",
    "offsets_trans = [(-0.3, -0.3), (0.15, -0.3), (0.15, 0.15), (-0.7, 0.15)]\n",
    "for pt, label, off in zip(pts_trans, labels_trans, offsets_trans):\n",
    "    ax.plot(*pt, 'o', color='#CC7000', markersize=7, zorder=5)\n",
    "    ax.text(pt[0] + off[0], pt[1] + off[1], label, fontsize=11, color='#CC7000')\n",
    "\n",
    "ax.set_xlim(-1, 5.5)\n",
    "ax.set_ylim(-1, 4.5)\n",
    "ax.set_aspect('equal')\n",
    "ax.grid(True, linestyle='--', alpha=0.4)\n",
    "ax.axhline(0, color='black', linewidth=0.8)\n",
    "ax.axvline(0, color='black', linewidth=0.8)\n",
    "ax.set_xlabel('$a$')\n",
    "ax.set_ylabel('$b$')\n",
    "ax.set_title('Transformed (parallelogram)', fontsize=12, color='gray')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
