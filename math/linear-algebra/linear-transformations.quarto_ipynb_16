    "```{ojs}\n",
    "//| echo: false\n",
    "\n",
    "// ── Main visualization ─────────────────────────────────────────────────────────\n",
    "\n",
    "{\n",
    "  const W = 420, H = 420;\n",
    "  const margin = 40;\n",
    "  const range = 4;\n",
    "\n",
    "  const sx = (x) => margin + (x + range) / (2 * range) * (W - 2 * margin);\n",
    "  const sy = (y) => H - margin - (y + range) / (2 * range) * (H - 2 * margin);\n",
    "\n",
    "  const container = d3.create(\"div\")\n",
    "    .style(\"display\", \"flex\").style(\"flex-wrap\", \"wrap\")\n",
    "    .style(\"gap\", \"16px\").style(\"justify-content\", \"center\");\n",
    "\n",
    "  // Face geometry\n",
    "  const faceHead = Array.from({length: 60}, (_, i) => {\n",
    "    const a = (i / 60) * 2 * Math.PI;\n",
    "    return [0.8 * Math.cos(a), 0.8 * Math.sin(a)];\n",
    "  });\n",
    "  const eyeRadius = 0.08;\n",
    "  const faceEyes = [[-0.3, 0.3], [0.3, 0.3]].map(([cx, cy]) =>\n",
    "    Array.from({length: 20}, (_, i) => {\n",
    "      const a = (i / 20) * 2 * Math.PI;\n",
    "      return [cx + eyeRadius * Math.cos(a), cy + eyeRadius * Math.sin(a)];\n",
    "    })\n",
    "  );\n",
    "  const faceMouth = Array.from({length: 21}, (_, i) => {\n",
    "    const a = Math.PI + (i / 20) * Math.PI;\n",
    "    return [0.35 * Math.cos(a), -0.15 + 0.2 * Math.sin(a)];\n",
    "  });\n",
    "\n",
    "  function drawPlot(parent, title, m, isT) {\n",
    "    const svg = parent.append(\"svg\").attr(\"width\", W).attr(\"height\", H)\n",
    "      .style(\"border\", \"1px solid #ddd\").style(\"border-radius\", \"8px\")\n",
    "      .style(\"background\", \"#fafafa\");\n",
    "\n",
    "    // Light grid\n",
    "    for (let i = -range; i <= range; i++) {\n",
    "      svg.append(\"line\").attr(\"x1\", sx(i)).attr(\"y1\", sy(-range))\n",
    "        .attr(\"x2\", sx(i)).attr(\"y2\", sy(range))\n",
    "        .attr(\"stroke\", \"#e0e0e0\").attr(\"stroke-width\", 0.5);\n",
    "      svg.append(\"line\").attr(\"x1\", sx(-range)).attr(\"y1\", sy(i))\n",
    "        .attr(\"x2\", sx(range)).attr(\"y2\", sy(i))\n",
    "        .attr(\"stroke\", \"#e0e0e0\").attr(\"stroke-width\", 0.5);\n",
    "    }\n",
    "\n",
    "    // Transformed grid\n",
    "    if (isT) {\n",
    "      const g = range + 1;\n",
    "      for (let i = -g; i <= g; i++) {\n",
    "        let [x1,y1] = transform(i, -g, m), [x2,y2] = transform(i, g, m);\n",
    "        svg.append(\"line\").attr(\"x1\",sx(x1)).attr(\"y1\",sy(y1))\n",
    "          .attr(\"x2\",sx(x2)).attr(\"y2\",sy(y2))\n",
    "          .attr(\"stroke\",\"#FFB347\").attr(\"stroke-width\",0.8).attr(\"opacity\",0.5);\n",
    "        [x1,y1] = transform(-g, i, m); [x2,y2] = transform(g, i, m);\n",
    "        svg.append(\"line\").attr(\"x1\",sx(x1)).attr(\"y1\",sy(y1))\n",
    "          .attr(\"x2\",sx(x2)).attr(\"y2\",sy(y2))\n",
    "          .attr(\"stroke\",\"#FFB347\").attr(\"stroke-width\",0.8).attr(\"opacity\",0.5);\n",
    "      }\n",
    "    }\n",
    "\n",
    "    // Axes\n",
    "    svg.append(\"line\").attr(\"x1\",sx(-range)).attr(\"y1\",sy(0))\n",
    "      .attr(\"x2\",sx(range)).attr(\"y2\",sy(0)).attr(\"stroke\",\"black\").attr(\"stroke-width\",1.2);\n",
    "    svg.append(\"line\").attr(\"x1\",sx(0)).attr(\"y1\",sy(-range))\n",
    "      .attr(\"x2\",sx(0)).attr(\"y2\",sy(range)).attr(\"stroke\",\"black\").attr(\"stroke-width\",1.2);\n",
    "\n",
    "    // Ticks\n",
    "    for (let i = -range; i <= range; i++) {\n",
    "      if (i === 0) continue;\n",
    "      svg.append(\"text\").attr(\"x\",sx(i)).attr(\"y\",sy(0)+15)\n",
    "        .attr(\"text-anchor\",\"middle\").attr(\"font-size\",10).attr(\"fill\",\"#666\").text(i);\n",
    "      svg.append(\"text\").attr(\"x\",sx(0)-12).attr(\"y\",sy(i)+4)\n",
    "        .attr(\"text-anchor\",\"middle\").attr(\"font-size\",10).attr(\"fill\",\"#666\").text(i);\n",
    "    }\n",
    "\n",
    "    // Parallelogram\n",
    "    const corners = isT\n",
    "      ? [[0,0], transform(v1[0],v1[1],m),\n",
    "         transform(v1[0]+v2[0],v1[1]+v2[1],m), transform(v2[0],v2[1],m)]\n",
    "      : [[0,0], v1, [v1[0]+v2[0],v1[1]+v2[1]], v2];\n",
    "\n",
    "    const fc = isT ? \"#FFB347\" : \"#87CEEB\";\n",
    "    const ec = isT ? \"#CC7000\" : \"#4682B4\";\n",
    "    svg.append(\"polygon\")\n",
    "      .attr(\"points\", corners.map(([x,y]) => `${sx(x)},${sy(y)}`).join(\" \"))\n",
    "      .attr(\"fill\",fc).attr(\"fill-opacity\",0.3).attr(\"stroke\",ec).attr(\"stroke-width\",2);\n",
    "    for (const [x,y] of corners)\n",
    "      svg.append(\"circle\").attr(\"cx\",sx(x)).attr(\"cy\",sy(y)).attr(\"r\",4).attr(\"fill\",ec);\n",
    "\n",
    "    // Arrows\n",
    "    for (const [color, id] of [[\"#4682B4\",\"b1\"],[\"#CC7000\",\"o1\"],[\"#2E8B57\",\"g1\"],[\"#C71585\",\"p1\"]]) {\n",
    "      svg.append(\"defs\").append(\"marker\").attr(\"id\",`ar-${id}`)\n",
    "        .attr(\"viewBox\",\"0 0 10 10\").attr(\"refX\",9).attr(\"refY\",5)\n",
    "        .attr(\"markerWidth\",8).attr(\"markerHeight\",8).attr(\"orient\",\"auto-start-reverse\")\n",
    "        .append(\"path\").attr(\"d\",\"M 0 0 L 10 5 L 0 10 z\").attr(\"fill\",color);\n",
    "    }\n",
    "\n",
    "    function arrow(tx, ty, color, markerId, label) {\n",
    "      const [px,py] = isT ? transform(tx,ty,m) : [tx,ty];\n",
    "      svg.append(\"line\").attr(\"x1\",sx(0)).attr(\"y1\",sy(0))\n",
    "        .attr(\"x2\",sx(px)).attr(\"y2\",sy(py))\n",
    "        .attr(\"stroke\",color).attr(\"stroke-width\",2.5)\n",
    "        .attr(\"marker-end\",`url(#ar-${markerId})`);\n",
    "      svg.append(\"text\").attr(\"x\",sx(px)+8).attr(\"y\",sy(py)-8)\n",
    "        .attr(\"font-size\",12).attr(\"fill\",color).attr(\"font-weight\",\"bold\").text(label);\n",
    "    }\n",
    "    arrow(v1[0],v1[1], isT?\"#CC7000\":\"#4682B4\", isT?\"o1\":\"b1\", isT?\"v₁'\":\"v₁\");\n",
    "    arrow(v2[0],v2[1], isT?\"#C71585\":\"#2E8B57\", isT?\"p1\":\"g1\", isT?\"v₂'\":\"v₂\");\n",
    "\n",
    "    // Face\n",
    "    if (showImageToggle) {\n",
    "      const tp = (x,y) => isT ? transform(x,y,m) : [x,y];\n",
    "      const headPath = faceHead.map(([x,y],i) => {\n",
    "        const [px,py] = tp(x,y);\n",
    "        return `${i===0?'M':'L'} ${sx(px)} ${sy(py)}`;\n",
    "      }).join(\" \") + \" Z\";\n",
    "      svg.append(\"path\").attr(\"d\",headPath)\n",
    "        .attr(\"fill\",\"none\").attr(\"stroke\",\"#555\").attr(\"stroke-width\",2);\n",
    "      for (const eyePts of faceEyes) {\n",
    "        const eyePath = eyePts.map(([x,y],i) => {\n",
    "          const [px,py] = tp(x,y);\n",
    "          return `${i===0?'M':'L'} ${sx(px)} ${sy(py)}`;\n",
    "        }).join(\" \") + \" Z\";\n",
    "        svg.append(\"path\").attr(\"d\",eyePath).attr(\"fill\",\"#555\").attr(\"stroke\",\"none\");\n",
    "      }\n",
    "      const mouthPath = faceMouth.map(([x,y],i) => {\n",
    "        const [px,py] = tp(x,y);\n",
    "        return `${i===0?'M':'L'} ${sx(px)} ${sy(py)}`;\n",
    "      }).join(\" \");\n",
    "      svg.append(\"path\").attr(\"d\",mouthPath)\n",
    "        .attr(\"fill\",\"none\").attr(\"stroke\",\"#555\").attr(\"stroke-width\",2);\n",
    "    }\n",
    "\n",
    "    svg.append(\"text\").attr(\"x\",W/2).attr(\"y\",20)\n",
    "      .attr(\"text-anchor\",\"middle\").attr(\"font-size\",14).attr(\"fill\",\"gray\").text(title);\n",
    "  }\n",
    "\n",
    "  drawPlot(container, \"Original\", {a:1,b:0,c:0,d:1}, false);\n",
    "  drawPlot(container, \"Transformed\", currentMat, true);\n",
    "\n",
    "  return container.node();\n",
    "}\n",
