        "def plot_lines(system):\n",
        "    \"\"\"Plot a 2x2 augmented matrix [A|b] as two lines.\"\"\"\n",
        "    fig, ax = plt.subplots(figsize=(6, 4))\n",
        "    colors = ['steelblue', 'darkorange']\n",
        "    x_vals = np.linspace(-10, 10, 400)\n",
