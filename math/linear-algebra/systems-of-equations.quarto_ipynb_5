        "                    label=f'${a:.0f}x_1 + {b:.0f}x_2 = {c:.0f}$')\n",
        "        else:\n",
        "            x_const = c / a\n",
        "            ax.axvline(x_const, color=colors[i], linewidth=2,\n",
        "                       label=f'${a:.0f}x_1 = {c:.0f}$')\n",
        "    ax.set_xlabel('$x_1$')\n",
        "    ax.set_ylabel('$x_2$')\n",
        "    ax.legend()\n",
        "    ax.grid(True, linestyle='--', alpha=0.5)\n",
        "    ax.set_xlim(-5, 5)\n",
