      "source": [
        "np.random.seed(42)\n",
        "\n",
        "# True relationship: y = 3*x1 - 2*x2 + 1 + noise\n",
        "m = 50\n",
        "X_train = np.random.randn(2, m)\n",
        "Y_train = 3 * X_train[0:1] - 2 * X_train[1:2] + 1 + 0.1 * np.random.randn(1, m)\n",
        "\n",
        "print(f\"Training data: X is {X_train.shape}, Y is {Y_train.shape}\")\n",
