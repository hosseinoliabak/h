        "parameters = nn_model(X_train, Y_train, num_iterations=2000, learning_rate=0.1, print_cost=True)\n",
        "\n",
        "print(f\"\\nLearned: W = {parameters['W'].round(4)}, b = {parameters['b'].round(4)}\")"
