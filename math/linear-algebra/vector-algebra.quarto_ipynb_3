      "cell_type": "code",
      "metadata": {},
      "source": [
        "u = np.array([1, 3])\n",
        "v = np.array([6, 2])\n",
        "\n",
        "cos_theta = np.dot(u, v) / (np.linalg.norm(u) * np.linalg.norm(v))\n",
        "theta = np.arccos(np.clip(cos_theta, -1, 1))\n",
